rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function hasFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function unchangedKeys(keys) {
      return !request.resource.data.diff(resource.data).changedKeys().hasAny(keys);
    }

    function statusIn(allowed) {
      return request.resource.data.status in allowed;
    }

    /* ------------------------------
       Core business collections
    ------------------------------ */

    match /orders/{orderId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && hasFields(["pharmacyId", "status", "pumpNumbers"])
        && request.resource.data.pharmacyId is string
        && request.resource.data.status is string
        && request.resource.data.pumpNumbers is list;

      allow update: if isSignedIn()
        && unchangedKeys([
          "pharmacyId",
          "customerId",
          "createdAt",
          "createdByEmployeeId",
          "createdByEmployeeName"
        ]);

      allow delete: if false;
    }

    match /pumps/{pumpId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && hasFields(["pharmacyId", "pumpNumber"])
        && request.resource.data.pharmacyId is string
        && request.resource.data.pumpNumber is string;

      allow update: if isSignedIn()
        && unchangedKeys([
          "pharmacyId",
          "pumpNumber",
          "createdAt",
          "createdByEmployeeId",
          "createdByEmployeeName"
        ]);

      allow delete: if false;
    }

    match /customers/{customerId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && hasFields(["pharmacyId", "customerName"])
        && request.resource.data.pharmacyId is string
        && request.resource.data.customerName is string;

      allow update: if isSignedIn()
        && unchangedKeys(["pharmacyId", "createdAt", "createdByEmployeeId", "createdByEmployeeName"]);

      allow delete: if false;
    }

    /* ------------------------------
       Identities & registration
    ------------------------------ */

    match /pharmacies/{pharmacyId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && hasFields(["pharmacyName", "pin", "securityPin6", "active"])
        && request.resource.data.pharmacyName is string
        && request.resource.data.pin is string
        && request.resource.data.securityPin6 is string
        && request.resource.data.pin.matches('^[0-9]{4}$')
        && request.resource.data.securityPin6.matches('^[0-9]{6}$')
        && request.resource.data.active is bool;

      allow update: if isSignedIn()
        && unchangedKeys(["pin", "securityPin6", "createdAt"]);

      allow delete: if false;
    }

    match /employees/{employeeId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && hasFields(["fullName", "pin", "active"])
        && request.resource.data.fullName is string
        && request.resource.data.pin is string
        && request.resource.data.active is bool;

      allow update: if isSignedIn()
        && unchangedKeys(["pin", "createdAt", "pharmacyId"]);

      allow delete: if false;
    }

    match /drivers/{driverId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && hasFields(["fullName", "pin", "active"])
        && request.resource.data.fullName is string
        && request.resource.data.pin is string
        && request.resource.data.active is bool;

      allow update: if isSignedIn()
        && unchangedKeys(["pin", "createdAt"]);

      allow delete: if false;
    }

    match /drivers/{driverId}/pharmacies/{connectionId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && hasFields(["pharmacyId"])
        && request.resource.data.pharmacyId is string;

      allow update: if isSignedIn();

      allow delete: if isSignedIn();
    }

    match /driver_location_points/{pointId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && hasFields(["driverId", "driverName", "pharmacyId", "status", "lat", "lng", "capturedAtMs"])
        && request.resource.data.driverId is string
        && request.resource.data.driverName is string
        && request.resource.data.pharmacyId is string
        && request.resource.data.status is string
        && request.resource.data.lat is number
        && request.resource.data.lng is number
        && request.resource.data.capturedAtMs is number;

      allow update, delete: if false;
    }

    /* ------------------------------
       Audit / legal artifacts
    ------------------------------ */

    match /pump_movements/{movementId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && hasFields(["pumpId", "pumpNumber", "pharmacyId", "action", "performedById", "role"])
        && request.resource.data.pumpId is string
        && request.resource.data.pumpNumber is string
        && request.resource.data.pharmacyId is string
        && request.resource.data.action in ["ASSIGNED", "PICKED_UP", "DELIVERED", "RETURNED"]
        && request.resource.data.role in ["EMPLOYEE", "DRIVER"];

      allow update, delete: if false;
    }

    match /signatures/{signatureId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && hasFields(["signatureBase64"])
        && request.resource.data.signatureBase64 is string;

      allow update, delete: if false;
    }

    match /deliverySignatures/{signatureId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && hasFields(["orderId", "signature", "driverSignature", "customerName", "driverName"])
        && request.resource.data.orderId is string
        && request.resource.data.signature is string
        && request.resource.data.driverSignature is string
        && request.resource.data.customerName is string
        && request.resource.data.driverName is string;

      allow update, delete: if false;
    }

    match /pickupSignatures/{signatureId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && hasFields(["orderId", "signature", "driverSignature", "employeeName", "driverName"])
        && request.resource.data.orderId is string
        && request.resource.data.signature is string
        && request.resource.data.driverSignature is string
        && request.resource.data.employeeName is string
        && request.resource.data.driverName is string;

      allow update, delete: if false;
    }

    /* ------------------------------
       Licensing / admin operations
    ------------------------------ */

    match /licenses/{licenseId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && hasFields(["code", "email", "status", "used", "createdBy"])
        && request.resource.data.code is string
        && request.resource.data.email is string
        && request.resource.data.used is bool
        && statusIn(["ACTIVE", "SUSPENDED", "CANCELLED"]);

      allow update: if isSignedIn()
        && unchangedKeys(["code", "email", "createdAt", "createdBy"])
        && statusIn(["ACTIVE", "SUSPENDED", "CANCELLED"]);

      allow delete: if isSignedIn() && resource.data.used == false;
    }

    /* ------------------------------
       Push Notifications
    ------------------------------ */

    match /notification_tokens/{tokenId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.resource.data.userId == tokenId;
    }

    match /notification_history/{historyId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    /* Deny unknown collections by default */
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
